# Copy to .env and fill in ONE key. Groq has a free tier: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
# Alternatives (use any one):
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

# ── Lab 8 (MCP) — NON-SECRET knobs, env-only. No real secret goes here. ──────
# The Python→Node seam ports + a synthetic dev bearer for the OAuth harden moves.
# MCP_DEV_TOKEN is a SYNTHETIC HS256 dev token minted by the lab (pyjwt), not a
# real credential; auth.ts/server.ts read process.env only and never inline it.
MCP_BRIDGE_PORT=8765
MCP_SERVER_PORT=9000
MCP_DEV_TOKEN=
# Expected RFC 8707 audience the server binds tokens to (Move 5). Placeholder URL,
# not a secret — the fixture token's `aud` must match this to pass validation.
MCP_EXPECTED_AUD=http://127.0.0.1:9000/mcp
